    @app.route("/api/orders/process", methods=["POST"])
    @login_required
    def api_order_process():
        try:
            file = request.files.get("file")
            customer_hint = request.form.get("customer_hint", "").strip()
            if not file:
                return jsonify({"success": False, "error": "No file uploaded"})
            business = Auth.get_current_business()
            user = Auth.get_current_user()
            biz_id = business.get("id") if business else None
            if not biz_id:
                return jsonify({"success": False, "error": "No business selected"})

            file_data = file.read()
            filename = file.filename.lower() if file.filename else "order.jpg"
            media_type = "application/pdf" if filename.endswith('.pdf') else ("image/png" if filename.endswith('.png') else "image/jpeg")
            if media_type.startswith('image/'):
                file_data = preprocess_image_for_ocr(file_data, filename)
            if len(file_data) > 3500000 and media_type.startswith('image/'):
                try:
                    from PIL import Image as PILImage
                    img = PILImage.open(io.BytesIO(file_data))
                    if img.mode in ('RGBA','P'):
                        img = img.convert('RGB')
                    img.thumbnail((1800,1800), PILImage.Resampling.LANCZOS)
                    output = io.BytesIO()
                    img.save(output, format='JPEG', quality=75, optimize=True)
                    file_data = output.getvalue()
                    media_type = "image/jpeg"
                except:
                    pass
            if len(file_data) > 4800000:
                return jsonify({"success": False, "error": "Image too large."})

            base64_data = base64.b64encode(file_data).decode('utf-8')
            logger.info(f"[ORDER] Jacqo scanning ({len(file_data)/1024:.0f}KB)")

            prompt = """You are reading a CUSTOMER ORDER (PO, WhatsApp order, fax, handwritten note, email).
Extract what they want to buy. Return ONLY JSON:
{
    "customer_name": "Company name",
    "customer_ref": "PO number if shown",
    "delivery_notes": "Any delivery instructions",
    "items": [
        {"description": "Item exactly as written", "qty": 10, "order_price": 0.00}
    ]
}
Rules: Copy descriptions EXACTLY. Read ALL items. If no qty, assume 1. If no price, set 0."""

            client = _anthropic_client
            message = client.messages.create(model="claude-sonnet-4-6", max_tokens=4000,
                messages=[{"role": "user", "content": [
                    {"type": "image", "source": {"type": "base64", "media_type": media_type, "data": base64_data}},
                    {"type": "text", "text": prompt}]}])
