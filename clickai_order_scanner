        async function rejectOrder() {{
            const reason = prompt('Reason for rejection (optional):');
            if (reason === null) return;  // Cancelled
            
            try {{
                const response = await fetch('/api/orders/reject', {{
                    method: 'POST',
                    headers: {{'Content-Type': 'application/json'}},
                    body: JSON.stringify({{ draft_id: draftId, reason: reason }})
                }});
                const data = await response.json();
                if (data.success) {{
                    window.location.href = '/orders/review';
                }}
            }} catch (err) {{
                alert('Error: ' + err.message);
            }}
        }}
        </script>
        '''
        
        return render_page("Review Draft Invoice", content, user, "orders")
    

    # ══════════════════════════════════════════════════════════════════════
    # API: /api/orders/approve — Approve draft → Create real invoice
    # ══════════════════════════════════════════════════════════════════════
    @app.route("/api/orders/approve", methods=["POST"])
    @login_required
    def api_order_approve():
        """
        Approve a draft invoice:
        1. Create real invoice with invoice number
        2. Deduct stock
        3. Create GL journal entries
        4. Update customer balance
        5. Mark draft as approved
        """
        
        try:
            data = request.get_json()
            business = Auth.get_current_business()
            user = Auth.get_current_user()
            biz_id = business.get("id") if business else None
            
            if not biz_id:
                return jsonify({"success": False, "error": "No business selected"})
            
            draft_id = data.get("draft_id")
            customer_id = data.get("customer_id", "")
            customer_name = data.get("customer_name", "")
            items_data = data.get("items", [])
            notes = data.get("notes", "")
            
            if not customer_id:
                return jsonify({"success": False, "error": "Please select a customer"})
            
            if not items_data:
                return jsonify({"success": False, "error": "No items to invoice"})
            
            # Build invoice items (only matched items with prices)
            invoice_items = []
            subtotal = Decimal("0")
            
            for item in items_data:
                if item.get("_removed"):
                    continue
                
                qty = Decimal(str(item.get("qty") or 1))
                price = Decimal(str(item.get("stock_price") or 0))
                line_total = (qty * price).quantize(Decimal("0.01"))
                subtotal += line_total
                
                invoice_items.append({
                    "code": item.get("code", ""),
                    "description": item.get("stock_description") or item.get("description", ""),
                    "qty": float(qty),
                    "price": float(price),
                    "total": float(line_total)
                })
            
            if subtotal <= 0:
                return jsonify({"success": False, "error": "Invoice total must be greater than zero. Check prices."})
            
            # Calculate VAT
            vat_amount = (subtotal * VAT_RATE).quantize(Decimal("0.01"))
            total = subtotal + vat_amount
            
            # Generate invoice number
            existing_invs = db.get("invoices", {"business_id": biz_id}) or []
            inv_number = next_document_number("INV-", existing_invs, "invoice_number")
            
            # Create invoice
            invoice = RecordFactory.invoice(
                business_id=biz_id,
                customer_id=customer_id,
                customer_name=customer_name,
                items=invoice_items,
                invoice_number=inv_number,
                date=today(),
                subtotal=float(subtotal),
                vat=float(vat_amount),
                total=float(total),
                status="outstanding",
                notes=notes,
                created_by=user.get("id", "") if user else ""
            )
            
            success, result = db.save("invoices", invoice)
            
            if not success:
                return jsonify({"success": False, "error": f"Failed to save invoice: {str(result)[:200]}"})
            
            invoice_id = invoice["id"]
            logger.info(f"[ORDER APPROVE] ✅ Invoice {inv_number} created: R{float(total):.2f}")
            
            # === DEDUCT STOCK ===
            all_stock = db.get_all_stock(biz_id)
            stock_by_code = {s.get("code", "").upper(): s for s in all_stock if s.get("code")}
            
            for item in invoice_items:
                code = (item.get("code") or "").upper()
                if code and code in stock_by_code:
                    stock_item = stock_by_code[code]
                    stock_id = stock_item.get("id")
                    current_qty = float(stock_item.get("qty") or stock_item.get("quantity") or 0)
                    sold_qty = float(item.get("qty") or 0)
                    new_qty = current_qty - sold_qty
                    db.update_stock(stock_id, {"qty": new_qty, "quantity": new_qty}, biz_id)
                    logger.info(f"[ORDER APPROVE] Stock {code}: {current_qty} - {sold_qty} = {new_qty}")
            
            # === UPDATE CUSTOMER BALANCE ===
            try:
                customer = db.get_one("customers", customer_id)
                if customer:
                    new_balance = float(customer.get("balance", 0)) + float(total)
                    db.update("customers", customer_id, {"balance": new_balance})
            except Exception as e:
                logger.error(f"[ORDER APPROVE] Balance update error: {e}")
            
            # === GL JOURNAL ENTRIES ===
            try:
                # Debit Debtors (1200), Credit Sales (4000) + VAT Output (2100)
                create_journal_entry(biz_id, today(), f"Invoice {inv_number} - {customer_name}", inv_number, [
                    {"account_code": "1200", "debit": float(total), "credit": 0},
                    {"account_code": "4000", "debit": 0, "credit": float(subtotal)},
                    {"account_code": "2100", "debit": 0, "credit": float(vat_amount)},
                ])
            except Exception as e:
                logger.error(f"[ORDER APPROVE] GL entry error (non-critical): {e}")
            
            # === UPDATE DRAFT STATUS ===
            try:
                db.save("order_drafts", {
                    "id": draft_id,
                    "status": "approved",
                    "invoice_id": invoice_id,
                    "invoice_number": inv_number,
                    "reviewed_by": user.get("id", "") if user else "",
                    "reviewed_at": now()
                })
            except Exception as e:
                logger.error(f"[ORDER APPROVE] Draft status update error: {e}")
            
            return jsonify({
                "success": True,
                "invoice_id": invoice_id,
                "invoice_number": inv_number,
                "total": float(total),
                "message": f"Invoice {inv_number} created successfully!"
            })
        
        except Exception as e:
            logger.error(f"[ORDER APPROVE] Error: {e}", exc_info=True)
            return jsonify({"success": False, "error": str(e)})
    

