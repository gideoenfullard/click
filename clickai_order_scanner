    def api_order_check_emails():
        try:
            business = Auth.get_current_business()
            user = Auth.get_current_user()
            biz_id = business.get("id") if business else None
            if not biz_id:
                return jsonify({"success": False, "error": "No business"})
            imap_host = business.get("imap_host", "imap.gmail.com")
            imap_user = business.get("imap_user", "")
            imap_pass = business.get("imap_pass", "")
            if not imap_user or not imap_pass:
                return jsonify({"success": False, "error": "Scanner inbox not configured."})

            emails = EmailScanner.fetch_new_emails(imap_host, imap_user, imap_pass)
            order_kw = ["order","bestelling","po ","purchase","quote request","kwotasie","please supply","lewer asb","benodig","need","require","rfq"]
            orders_found = 0
            for email_data in emails:
                sender = email_data.get("sender","")
                subject = email_data.get("subject","")
                is_order = any(kw in subject.lower() for kw in order_kw)
                for att in email_data.get("attachments",[]):
                    try:
                        processed = EmailScanner.process_attachment(att.get("data"), att.get("filename","unknown"), att.get("content_type","application/octet-stream"))
                        classification = processed.get("classification","")
                        extracted = processed.get("extracted_data",{})
                        if (is_order or classification in ("customer_order","purchase_order","quote_request")) and extracted.get("items"):
                            img = base64.b64encode(att.get("data",b"")).decode("utf-8") if att.get("data") else ""
                            s, _ = run_order_pipeline(biz_id=biz_id, user_id=user.get("id","") if user else "", ocr_data=extracted, source_type="email", source_sender=sender, source_subject=subject, source_filename=att.get("filename",""), image_data=img)
                            if s:
                                orders_found += 1
                    except Exception as e:
                        logger.error(f"[ORDER EMAIL] {e}")
