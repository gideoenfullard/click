    # API: /api/orders/reject — Reject draft with reason
    # ══════════════════════════════════════════════════════════════════════
    @app.route("/api/orders/reject", methods=["POST"])
    @login_required
    def api_order_reject():
        """Reject a draft order"""
        try:
            data = request.get_json()
            user = Auth.get_current_user()
            
            db.save("order_drafts", {
                "id": data.get("draft_id"),
                "status": "rejected",
                "reject_reason": data.get("reason", ""),
                "reviewed_by": user.get("id", "") if user else "",
                "reviewed_at": now()
            })
            
            return jsonify({"success": True})
        except Exception as e:
            return jsonify({"success": False, "error": str(e)})
    

