                        📦 Scan New Order
                    </a>
                </div>
            </div>
            
            <!-- PENDING REVIEW -->
            <h3 style="margin-bottom:10px;">🔴 Pending Review ({len(pending)})</h3>
            <div style="overflow-x:auto;margin-bottom:30px;">
                <table class="data-table" style="width:100%;">
                    <thead>
                        <tr>
                            <th style="width:30px;"></th>
                            <th>Customer</th>
                            <th style="text-align:center;">Items</th>
                            <th style="text-align:center;">Matched</th>
                            <th style="text-align:center;">Flags</th>
                            <th style="text-align:right;">Total</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {pending_rows}
                    </tbody>
                </table>
            </div>
            
            {"" if not saved else f"""
            <!-- SAVED FOR LATER -->
            <details style="margin-bottom:30px;">
                <summary style="cursor:pointer;font-size:16px;font-weight:bold;color:var(--text-muted);">⏸ Saved for Later ({len(saved)})</summary>
                <div style="overflow-x:auto;margin-top:10px;">
                    <table class="data-table" style="width:100%;">
                        <thead>
                            <tr>
                                <th style="width:30px;"></th>
                                <th>Customer</th>
                                <th style="text-align:center;">Items</th>
                                <th style="text-align:center;">Matched</th>
                                <th style="text-align:center;">Flags</th>
                                <th style="text-align:right;">Total</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>{saved_rows}</tbody>
                    </table>
                </div>
            </details>
            """}
            
            {"" if not history else f"""
            <!-- HISTORY -->
            <details>
                <summary style="cursor:pointer;font-size:16px;font-weight:bold;color:var(--text-muted);">📜 History ({len(history)})</summary>
                <div style="overflow-x:auto;margin-top:10px;">
                    <table class="data-table" style="width:100%;">
