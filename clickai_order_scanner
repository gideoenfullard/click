    # ══════════════════════════════════════════════════════════════════════
    # API: /api/orders/process — Full pipeline: OCR → Match → Draft
    # ══════════════════════════════════════════════════════════════════════
    @app.route("/api/orders/process", methods=["POST"])
    @login_required
    def api_order_process():
        """
        Full Order-to-Invoice Pipeline:
        1. Jacqo OCR reads the document
        2. Zane matches items against stock (fuzzy match)
        3. Jayden calculates using YOUR selling prices
        4. Creates draft invoice for Daphny review
        """
        
        try:
            file = request.files.get("file")
            customer_hint = request.form.get("customer_hint", "").strip()
            
            if not file:
                return jsonify({"success": False, "error": "No file uploaded"})
            
            business = Auth.get_current_business()
            user = Auth.get_current_user()
            biz_id = business.get("id") if business else None
            
            if not biz_id:
                return jsonify({"success": False, "error": "No business selected"})
            
            # Read file
            file_data = file.read()
            filename = file.filename.lower() if file.filename else "order.jpg"
            
            # Determine media type
            if filename.endswith('.pdf'):
                media_type = "application/pdf"
            elif filename.endswith('.png'):
                media_type = "image/png"
            elif filename.endswith('.gif'):
                media_type = "image/gif"
            elif filename.endswith('.webp'):
                media_type = "image/webp"
            else:
                media_type = "image/jpeg"
            
            # ── STEP 1: Preprocess image ──
            if media_type.startswith('image/'):
                file_data = preprocess_image_for_ocr(file_data, filename)
            
            # Compress if too large
            MAX_SIZE = 3500000
            if len(file_data) > MAX_SIZE and media_type.startswith('image/'):
                try:
                    from PIL import Image as PILImage
                    img = PILImage.open(io.BytesIO(file_data))
                    if img.mode in ('RGBA', 'P'):
                        img = img.convert('RGB')
                    max_dim = 1800
                    if img.width > max_dim or img.height > max_dim:
                        img.thumbnail((max_dim, max_dim), PILImage.Resampling.LANCZOS)
                    output = io.BytesIO()
                    img.save(output, format='JPEG', quality=75, optimize=True)
                    file_data = output.getvalue()
                    media_type = "image/jpeg"
                except Exception as e:
                    logger.warning(f"[ORDER] Image compression failed: {e}")
            
            if len(file_data) > 4800000:
                return jsonify({"success": False, "error": "Image too large. Please take a lower resolution photo."})
            
            base64_data = base64.b64encode(file_data).decode('utf-8')
            # Keep a smaller version for storage (thumbnail)
            image_for_storage = base64_data[:500000]  # Cap at ~375KB for DB storage
            
            # ── STEP 2: Jacqo OCR — Extract order items ──
            logger.info(f"[ORDER] Jacqo scanning customer order ({len(file_data)/1024:.0f}KB)")
            
            prompt = """You are reading a CUSTOMER ORDER (purchase order, WhatsApp order, fax order, handwritten order, or email order).

This is NOT a supplier invoice — this is a customer placing an order with us. Extract what they want to buy.

Extract the customer name and ALL items they are ordering.

Rules:
1. Copy item descriptions EXACTLY as written
2. Get quantities — if no qty specified, assume 1
3. If prices are shown on the order, include them as "order_price" — but these are the customer's prices, not necessarily ours
4. Get customer name/company if visible
5. Get any reference numbers, PO numbers, delivery instructions
6. Read ALL items — do not skip any

Return ONLY JSON:
{
    "customer_name": "Company or person name",
    "customer_ref": "PO number or reference if shown",
    "delivery_notes": "Any delivery instructions",
    "items": [
        {"description": "Item exactly as written", "qty": 10, "order_price": 0.00},
        {"description": "Another item", "qty": 5, "order_price": 0.00}
    ]
}

NOTE: If no price is visible for an item, set order_price to 0.
If customer name is not clear, set to empty string."""
            
            client = _anthropic_client
            message = client.messages.create(
                model="claude-sonnet-4-6",
                max_tokens=4000,
                messages=[{
                    "role": "user",
                    "content": [
                        {"type": "image", "source": {"type": "base64", "media_type": media_type, "data": base64_data}},
                        {"type": "text", "text": prompt}
                    ]
                }]
            )
            
            raw_text = message.content[0].text.strip()
            ocr_data = extract_json_from_text(raw_text)
            
            if not ocr_data:
                logger.error(f"[ORDER] Jacqo could not parse: {raw_text[:200]}")
                return jsonify({"success": False, "error": "Could not read order items. Try a clearer photo."})
            
            ocr_items = ocr_data.get("items", [])
            if not ocr_items:
                return jsonify({"success": False, "error": "No items found on this order. Is this a customer order?"})
            
            logger.info(f"[ORDER] Jacqo extracted {len(ocr_items)} items from order")
            
            # ── STEP 3: Stock Match (Zane logic) ──
            all_stock = db.get_all_stock(biz_id)
            
            matched_items = []
            items_matched = 0
            items_flagged = 0
            subtotal = Decimal("0")
            
            for item in ocr_items:
                desc = (item.get("description") or "").strip()
                qty = float(item.get("qty") or item.get("quantity") or 1)
                order_price = float(item.get("order_price") or item.get("price") or 0)
                
                if not desc:
                    continue
                
                # Fuzzy match against stock
                stock_item, confidence = fuzzy_match_stock(desc, all_stock)
                
                if stock_item and confidence >= 50:
                    # ── STEP 4: Jayden calculates from YOUR price list ──
                    selling_price = float(stock_item.get("price") or stock_item.get("selling_price") or 0)
                    line_total = round(qty * selling_price, 2)
                    subtotal += Decimal(str(line_total))
                    
                    matched_items.append({
                        "description": desc,
                        "stock_description": stock_item.get("description", ""),
                        "code": stock_item.get("code", ""),
                        "stock_id": stock_item.get("id", ""),
                        "qty": qty,
                        "stock_price": selling_price,
                        "order_price": order_price,
                        "line_total": line_total,
                        "matched": True,
                        "confidence": confidence,
                        "flagged": False,
                        "flag_reason": "",
                        "stock_qty": float(stock_item.get("qty") or stock_item.get("quantity") or 0)
                    })
                    items_matched += 1
                    logger.info(f"[ORDER] ✓ Matched: '{desc}' → '{stock_item.get('code')} {stock_item.get('description')}' ({confidence}%)")
                else:
                    # Flagged — not in stock
                    matched_items.append({
                        "description": desc,
                        "stock_description": "",
                        "code": "",
                        "stock_id": "",
                        "qty": qty,
                        "stock_price": 0,
                        "order_price": order_price,
                        "line_total": 0,
                        "matched": False,
                        "confidence": confidence,
                        "flagged": True,
                        "flag_reason": "Item not found in stock" if confidence < 30 else f"Low confidence match ({confidence}%)",
                        "stock_qty": 0
                    })
                    items_flagged += 1
                    logger.info(f"[ORDER] ⚠ Flagged: '{desc}' — no stock match (best: {confidence}%)")
            
            # ── Calculate totals (Jayden) ──
            vat_amount = (subtotal * Decimal("0.15")).quantize(Decimal("0.01"))
            total = subtotal + vat_amount
            
            # ── Customer match ──
            customer_name = customer_hint or ocr_data.get("customer_name", "")
            customer = match_customer(customer_name, biz_id) if customer_name else None
            
            # ── STEP 5: Create Draft Invoice ──
            draft_id = generate_id()
            draft = {
                "id": draft_id,
                "business_id": biz_id,
                "source_type": "scan",
                "source_sender": "",
                "source_subject": "",
                "source_filename": filename,
                "original_image": image_for_storage,
                "ocr_raw_text": raw_text[:5000],
                "customer_id": customer.get("id", "") if customer else "",
                "customer_name": customer.get("name", "") if customer else customer_name,
                "customer_matched": bool(customer),
                "items": json.dumps(matched_items),
                "subtotal": float(subtotal),
                "vat": float(vat_amount),
                "total": float(total),
                "status": "pending_review",
                "created_at": now(),
                "created_by": user.get("id", "") if user else "",
                "notes": ocr_data.get("delivery_notes", "") or ""
            }
            
            # Add customer ref if found
            if ocr_data.get("customer_ref"):
                draft["notes"] = f"PO/Ref: {ocr_data['customer_ref']}\n{draft['notes']}".strip()
            
            success, result = db.save("order_drafts", draft)
            
            if success:
                logger.info(f"[ORDER] ✅ Draft created: {draft_id} — {len(matched_items)} items, {items_matched} matched, {items_flagged} flagged, total R{float(total):.2f}")
                return jsonify({
                    "success": True,
                    "draft": {
                        "id": draft_id,
                        "customer_name": draft["customer_name"],
                        "items_total": len(matched_items),
                        "items_matched": items_matched,
                        "items_flagged": items_flagged,
                        "subtotal": float(subtotal),
                        "vat": float(vat_amount),
                        "total": float(total)
                    }
                })
            else:
                logger.error(f"[ORDER] Failed to save draft: {result}")
                return jsonify({"success": False, "error": f"Failed to save draft. Run the SQL setup first. Error: {str(result)[:200]}"})
        
        except Exception as e:
            logger.error(f"[ORDER] Pipeline error: {e}", exc_info=True)
            return jsonify({"success": False, "error": str(e)})
    

    # ══════════════════════════════════════════════════════════════════════
    # API: /api/orders/process-email — Process order from email
    # ══════════════════════════════════════════════════════════════════════
    @app.route("/api/orders/process-email", methods=["POST"])
    @login_required
    def api_order_process_email():
        """Process a customer order that arrived via email — same pipeline but source=email"""
        
        try:
            data = request.get_json()
            business = Auth.get_current_business()
            user = Auth.get_current_user()
            biz_id = business.get("id") if business else None
            
            if not biz_id:
                return jsonify({"success": False, "error": "No business selected"})
            
            # Get email data
            sender = data.get("sender", "")
            subject = data.get("subject", "")
            image_data = data.get("image_data", "")  # base64
            ocr_data = data.get("extracted", {})
            
            if not ocr_data.get("items"):
                return jsonify({"success": False, "error": "No items extracted from email"})
            
            ocr_items = ocr_data.get("items", [])
            
            # Same pipeline: stock match + price calc
            all_stock = db.get_all_stock(biz_id)
            matched_items = []
            items_matched = 0
            items_flagged = 0
            subtotal = Decimal("0")
            
            for item in ocr_items:
                desc = (item.get("description") or "").strip()
                qty = float(item.get("qty") or 1)
                order_price = float(item.get("order_price") or item.get("price") or 0)
                
                if not desc:
                    continue
                
                stock_item, confidence = fuzzy_match_stock(desc, all_stock)
                
                if stock_item and confidence >= 50:
                    selling_price = float(stock_item.get("price") or stock_item.get("selling_price") or 0)
                    line_total = round(qty * selling_price, 2)
                    subtotal += Decimal(str(line_total))
                    
                    matched_items.append({
                        "description": desc,
                        "stock_description": stock_item.get("description", ""),
                        "code": stock_item.get("code", ""),
                        "stock_id": stock_item.get("id", ""),
                        "qty": qty,
                        "stock_price": selling_price,
                        "order_price": order_price,
                        "line_total": line_total,
                        "matched": True,
                        "confidence": confidence,
                        "flagged": False,
                        "flag_reason": "",
                        "stock_qty": float(stock_item.get("qty") or stock_item.get("quantity") or 0)
                    })
                    items_matched += 1
                else:
                    matched_items.append({
                        "description": desc,
                        "stock_description": "",
                        "code": "",
                        "stock_id": "",
                        "qty": qty,
                        "stock_price": 0,
                        "order_price": order_price,
                        "line_total": 0,
                        "matched": False,
                        "confidence": confidence,
                        "flagged": True,
                        "flag_reason": "Item not found in stock",
                        "stock_qty": 0
                    })
                    items_flagged += 1
            
            vat_amount = (subtotal * Decimal("0.15")).quantize(Decimal("0.01"))
            total = subtotal + vat_amount
            
            # Customer match from sender email or extracted name
            customer_name = ocr_data.get("customer_name", "") or sender.split("@")[0] if sender else ""
            customer = match_customer(customer_name, biz_id) if customer_name else None
            
            # Also try matching by email domain
            if not customer and sender:
                domain = sender.split("@")[-1].split(".")[0] if "@" in sender else ""
                if domain and len(domain) > 3:
                    customer = match_customer(domain, biz_id)
            
            draft_id = generate_id()
            draft = {
                "id": draft_id,
                "business_id": biz_id,
                "source_type": "email",
                "source_sender": sender,
                "source_subject": subject,
                "source_filename": "",
                "original_image": image_data[:500000] if image_data else "",
                "ocr_raw_text": json.dumps(ocr_data)[:5000],
                "customer_id": customer.get("id", "") if customer else "",
                "customer_name": customer.get("name", "") if customer else customer_name,
                "customer_matched": bool(customer),
                "items": json.dumps(matched_items),
                "subtotal": float(subtotal),
                "vat": float(vat_amount),
                "total": float(total),
                "status": "pending_review",
                "created_at": now(),
                "created_by": user.get("id", "") if user else "",
                "notes": f"Email from: {sender}\nSubject: {subject}"
            }
            
            success, result = db.save("order_drafts", draft)
            
            if success:
                logger.info(f"[ORDER EMAIL] ✅ Draft from email: {draft_id} — {sender}")
                return jsonify({"success": True, "draft_id": draft_id})
            
            return jsonify({"success": False, "error": "Failed to save draft"})
        
        except Exception as e:
            logger.error(f"[ORDER EMAIL] Error: {e}")
            return jsonify({"success": False, "error": str(e)})
    

    # ══════════════════════════════════════════════════════════════════════
    # API: /api/orders/check-emails — Check email inbox for customer orders
    # ══════════════════════════════════════════════════════════════════════
    @app.route("/api/orders/check-emails", methods=["POST"])
    @login_required
    def api_order_check_emails():
        """
        Check scanner inbox for emails that look like customer orders.
        Uses existing EmailScanner + Jacqo, but routes to order pipeline 
        instead of supplier invoice pipeline.
        """
        
        try:
            business = Auth.get_current_business()
            user = Auth.get_current_user()
            biz_id = business.get("id") if business else None
            
            if not biz_id:
                return jsonify({"success": False, "error": "No business selected"})
            
            # Get IMAP settings
            imap_host = business.get("imap_host") or ""
            imap_user = business.get("imap_user") or ""
            imap_pass = business.get("imap_pass") or ""
            
            if not imap_user or not imap_pass:
                return jsonify({"success": False, "error": "Scanner inbox not configured. Go to Settings → Scanner Inbox."})
            
            # Fetch emails
            emails = EmailScanner.fetch_new_emails(imap_host, imap_user, imap_pass)
            logger.info(f"[ORDER EMAIL] Found {len(emails)} emails to check")
            
            orders_found = 0
            errors = []
            
            for email_data in emails:
                sender = email_data.get("sender", "")
                subject = email_data.get("subject", "")
                
                # Check if this looks like a customer order
                order_keywords = ["order", "bestelling", "po ", "purchase", "quote request", 
                                  "kwotasie", "please supply", "lewer asb", "benodig",
                                  "need", "require", "request"]
                is_order = any(kw in subject.lower() for kw in order_keywords)
                
                # Process attachments
                for attachment in email_data.get("attachments", []):
                    try:
                        processed = EmailScanner.process_attachment(
                            attachment.get("data"),
                            attachment.get("filename", "unknown"),
                            attachment.get("content_type", "application/octet-stream")
                        )
                        
                        # Check if AI classified it as a customer order
                        classification = processed.get("classification", "")
                        extracted = processed.get("extracted_data", {})
                        
                        # If it looks like a customer order (by subject or classification), 
                        # route to our pipeline
                        if is_order or classification in ("customer_order", "purchase_order", "quote_request"):
                            image_b64 = base64.b64encode(attachment.get("data", b"")).decode("utf-8") if attachment.get("data") else ""
                            
                            # Process through our order pipeline
                            # Use the extracted items or re-extract
                            items = extracted.get("items", [])
                            if items:
                                # Stock match
                                all_stock = db.get_all_stock(biz_id)
                                matched_items = []
                                items_matched = 0
                                items_flagged = 0
                                subtotal = Decimal("0")
                                
                                for item in items:
                                    desc = (item.get("description") or "").strip()
                                    qty = float(item.get("qty") or 1)
                                    
                                    if not desc:
                                        continue
                                    
                                    stock_item, confidence = fuzzy_match_stock(desc, all_stock)
                                    
                                    if stock_item and confidence >= 50:
                                        sp = float(stock_item.get("price") or stock_item.get("selling_price") or 0)
                                        lt = round(qty * sp, 2)
                                        subtotal += Decimal(str(lt))
                                        matched_items.append({
                                            "description": desc,
                                            "stock_description": stock_item.get("description", ""),
                                            "code": stock_item.get("code", ""),
                                            "stock_id": stock_item.get("id", ""),
                                            "qty": qty,
                                            "stock_price": sp,
                                            "order_price": float(item.get("price") or 0),
                                            "line_total": lt,
                                            "matched": True,
                                            "confidence": confidence,
                                            "flagged": False,
                                            "flag_reason": "",
                                            "stock_qty": float(stock_item.get("qty") or 0)
                                        })
                                        items_matched += 1
                                    else:
                                        matched_items.append({
                                            "description": desc, "stock_description": "", "code": "", "stock_id": "",
                                            "qty": qty, "stock_price": 0,
                                            "order_price": float(item.get("price") or 0),
                                            "line_total": 0, "matched": False, "confidence": confidence,
                                            "flagged": True, "flag_reason": "Not in stock", "stock_qty": 0
                                        })
                                        items_flagged += 1
                                
                                vat = (subtotal * Decimal("0.15")).quantize(Decimal("0.01"))
                                total = subtotal + vat
                                
                                customer_name = extracted.get("customer_name", "") or sender.split("@")[0]
                                customer = match_customer(customer_name, biz_id)
                                
                                draft = {
                                    "id": generate_id(),
                                    "business_id": biz_id,
                                    "source_type": "email",
                                    "source_sender": sender,
                                    "source_subject": subject,
                                    "source_filename": attachment.get("filename", ""),
                                    "original_image": image_b64[:500000],
                                    "ocr_raw_text": json.dumps(extracted)[:5000],
                                    "customer_id": customer.get("id", "") if customer else "",
                                    "customer_name": customer.get("name", "") if customer else customer_name,
                                    "customer_matched": bool(customer),
                                    "items": json.dumps(matched_items),
                                    "subtotal": float(subtotal),
                                    "vat": float(vat),
                                    "total": float(total),
                                    "status": "pending_review",
                                    "created_at": now(),
                                    "created_by": user.get("id", "") if user else "",
                                    "notes": f"Email from: {sender}\nSubject: {subject}"
                                }
                                
                                db.save("order_drafts", draft)
                                orders_found += 1
                                logger.info(f"[ORDER EMAIL] ✅ Order from {sender}: {len(matched_items)} items")
                    
                    except Exception as e:
                        logger.error(f"[ORDER EMAIL] Error processing attachment: {e}")
                        errors.append(str(e))
            
            return jsonify({
                "success": True,
                "orders_found": orders_found,
                "emails_checked": len(emails),
                "errors": errors
            })
        
        except Exception as e:
            logger.error(f"[ORDER EMAIL CHECK] Error: {e}")
            return jsonify({"success": False, "error": str(e)})
    

