        if not biz_id:
            return render_page("Order Review", "<div class='card'><p>No business selected</p></div>", user, "orders")
        
        # Get all drafts
        try:
            drafts = db.get("order_drafts", {"business_id": biz_id}) or []
        except Exception as e:
            logger.error(f"[ORDER REVIEW] Error loading drafts: {e}")
            drafts = []
        
        # Separate by status
        pending = [d for d in drafts if d.get("status") == "pending_review"]
        saved = [d for d in drafts if d.get("status") == "saved_later"]
        approved = [d for d in drafts if d.get("status") == "approved"]
        rejected = [d for d in drafts if d.get("status") == "rejected"]
        
        # Sort pending by newest first
        pending.sort(key=lambda x: x.get("created_at", ""), reverse=True)
        saved.sort(key=lambda x: x.get("created_at", ""), reverse=True)
        
        def build_row(d, show_status=False):
            items = json.loads(d.get("items", "[]")) if isinstance(d.get("items"), str) else (d.get("items") or [])
            flagged = len([i for i in items if i.get("flagged")])
            total_items = len(items)
            matched = len([i for i in items if i.get("matched")])
            total = float(d.get("total") or 0)
            customer = d.get("customer_name") or "Unknown"
            source = d.get("source_type", "scan")
            source_icon = {"scan": "📷", "email": "📧", "whatsapp": "💬"}.get(source, "📄")
            created = d.get("created_at", "")[:16].replace("T", " ")
            status = d.get("status", "")
            
            status_badge = ""
            if show_status:
                status_colors = {"approved": "var(--green)", "rejected": "var(--red)", "saved_later": "#f59e0b"}
                status_labels = {"approved": "✅ Approved", "rejected": "❌ Rejected", "saved_later": "⏸ Saved"}
                status_badge = f'<span style="background:{status_colors.get(status, "var(--text-muted)")};color:white;padding:2px 8px;border-radius:10px;font-size:11px;margin-left:8px;">{status_labels.get(status, status)}</span>'
            
            flag_badge = f'<span style="color:var(--red);font-weight:bold;">⚠ {flagged}</span>' if flagged > 0 else '<span style="color:var(--green);">✓</span>'
            
            inv_link = ""
            if d.get("invoice_number"):
                inv_link = f' → <a href="/invoice/{d.get("invoice_id", "")}" style="color:var(--primary);">{d.get("invoice_number")}</a>'
            
            return f'''
            <tr onclick="window.location='/orders/review/{d.get("id")}'" style="cursor:pointer;">
                <td>{source_icon}</td>
                <td><strong>{safe_string(customer)}</strong>{status_badge}{inv_link}</td>
                <td style="text-align:center;">{total_items}</td>
                <td style="text-align:center;">{matched}/{total_items}</td>
                <td style="text-align:center;">{flag_badge}</td>
                <td style="text-align:right;font-weight:bold;">R{total:,.2f}</td>
                <td style="color:var(--text-muted);font-size:12px;">{created}</td>
            </tr>
            '''
        
        # Build pending rows
        pending_rows = ""
        for d in pending:
            pending_rows += build_row(d)
        
        if not pending_rows:
            pending_rows = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No orders waiting for review 🎉</td></tr>'
        
        # Build saved rows
        saved_rows = ""
        for d in saved:
            saved_rows += build_row(d, show_status=True)
        
        # Build history rows (last 20)
        history_rows = ""
        history = sorted(approved + rejected, key=lambda x: x.get("reviewed_at", x.get("created_at", "")), reverse=True)[:20]
        for d in history:
