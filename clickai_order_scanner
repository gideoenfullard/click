    # API: /api/orders/save-later — Save draft for later review
    # ══════════════════════════════════════════════════════════════════════
    @app.route("/api/orders/save-later", methods=["POST"])
    @login_required
    def api_order_save_later():
        """Save draft for later — keeps it in the queue"""
        try:
            data = request.get_json()
            draft_id = data.get("draft_id")
            
            db.save("order_drafts", {
                "id": draft_id,
                "status": "saved_later"
            })
            
            return jsonify({"success": True})
        except Exception as e:
            return jsonify({"success": False, "error": str(e)})
    

