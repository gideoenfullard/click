    def fuzzy_match_stock(search_text, all_stock):
        """
        Fuzzy match an order line item against stock database.
        Returns: (stock_item, confidence) or (None, 0)
        
        Handles things like:
        - "25mm tube" → "TUBE SS 25MM"
        - "M16x80 bolt" → "BLT HT M16X80"
        - "3m angle iron 40x40" → "ANGLE 40X40X3 6M"
        """
        search_text = search_text.lower().strip()
        if not search_text or not all_stock:
            return None, 0
        
        # Normalize: remove common filler words
        filler = {'pcs', 'piece', 'pieces', 'each', 'ea', 'per', 'x', 'no', 'nr', 'of', 'the', 'a', 'an', 'and', 'or', 'with', 'for'}
        
        # Extract meaningful search tokens
        search_words = []
        for w in search_text.replace('-', ' ').replace('/', ' ').split():
            w = w.strip().lower()
            if not w or w in filler:
                continue
            search_words.append(w)
            # Handle m-prefix sizes: m16 → also search "16"
            if w.startswith('m') and len(w) > 1 and w[1:].replace('.', '').isdigit():
                search_words.append(w[1:])
            # Handle mm suffix: 25mm → also search "25"
            if w.endswith('mm') and len(w) > 2 and w[:-2].replace('.', '').isdigit():
                search_words.append(w[:-2])
        
        if not search_words:
            return None, 0
        
        best_match = None
        best_score = 0
        best_pct = 0
        
        for item in all_stock:
            desc = (item.get("description") or "").lower()
            code = (item.get("code") or "").lower()
            combined = f"{code} {desc}"
            
            # Count matching words
            matches = sum(1 for word in search_words if word in combined)
            pct = matches / len(search_words) if search_words else 0
            
            if matches > 0 and pct >= 0.5:  # At least 50% word match
                if matches > best_score or (matches == best_score and len(desc) < len(best_match.get("description", "") if best_match else "x" * 999)):
                    best_score = matches
                    best_pct = pct
                    best_match = item
        
        confidence = round(best_pct * 100)
        return best_match, confidence
    
    
    def match_customer(name_text, biz_id):
        """Try to match customer name from order text against customer database"""
        if not name_text or not biz_id:
            return None
        
        customers = db.get("customers", {"business_id": biz_id}) or []
        name_lower = name_text.lower().strip()
        
        # Exact match first
        for c in customers:
            if name_lower == (c.get("name") or "").lower():
                return c
        
        # Partial match
        for c in customers:
            c_name = (c.get("name") or "").lower()
            if name_lower in c_name or c_name in name_lower:
                return c
        
        # Word overlap match (for "NDE Engineering" matching "NDE Engineering CC")
        name_words = set(name_lower.split())
        for c in customers:
            c_words = set((c.get("name") or "").lower().split())
            overlap = name_words & c_words
            if len(overlap) >= min(2, len(name_words)):
                return c
        
        return None
    

