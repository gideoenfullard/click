            const price = parseFloat(document.querySelector(`.item-price[data-index="${{idx}}"]`).value) || 0;
            const total = qty * price;
            
            draftItems[idx].qty = qty;
            draftItems[idx].stock_price = price;
            draftItems[idx].line_total = total;
            
            document.querySelector(`.item-total[data-index="${{idx}}"]`).textContent = 'R' + total.toFixed(2).replace(/\\B(?=(\\d{{3}})+(?!\\d))/g, ',');
            
            recalcTotals();
        }}
        
        function recalcTotals() {{
            let subtotal = 0;
            draftItems.forEach(item => {{
                if (!item._removed) subtotal += item.line_total || 0;
            }});
            const vat = subtotal * 0.15;
            const total = subtotal + vat;
            
            document.getElementById('subtotalDisplay').textContent = 'R' + subtotal.toFixed(2).replace(/\\B(?=(\\d{{3}})+(?!\\d))/g, ',');
            document.getElementById('vatDisplay').textContent = 'R' + vat.toFixed(2).replace(/\\B(?=(\\d{{3}})+(?!\\d))/g, ',');
            document.getElementById('totalDisplay').textContent = 'R' + total.toFixed(2).replace(/\\B(?=(\\d{{3}})+(?!\\d))/g, ',');
        }}
        
        function removeItem(idx) {{
            if (!confirm('Remove this item?')) return;
            draftItems[idx]._removed = true;
            const row = document.querySelector(`tr[data-index="${{idx}}"]`);
            if (row) row.style.display = 'none';
            recalcTotals();
        }}
        
        function manualMatch(idx) {{
            const search = prompt('Search stock by code or description:');
            if (!search) return;
            
            // Search stock via API
            fetch('/api/stock/search?q=' + encodeURIComponent(search) + '&limit=10')
                .then(r => r.json())
                .then(data => {{
                    if (data.success && data.total > 0) {{
                        // For simplicity, take the first result - could show a picker
                        alert('Stock search found ' + data.total + ' items. Use the Review Queue to manually select.');
                    }}
                }});
        }}
        
        async function approveOrder() {{
            const customerSelect = document.getElementById('customerSelect');
            const customerId = customerSelect.value;
            const customerName = customerSelect.selectedOptions[0]?.text || '';
            
            if (!customerId) {{
                alert('Please select a customer before approving.');
                return;
            }}
            
            // Filter out removed items
            const activeItems = draftItems.filter(i => !i._removed);
            if (activeItems.length === 0) {{
                alert('No items in the draft.');
                return;
            }}
            
            const btn = document.getElementById('approveBtn');
            btn.innerHTML = '⏳ Creating Invoice...';
            btn.disabled = true;
            
            try {{
                const response = await fetch('/api/orders/approve', {{
                    method: 'POST',
                    headers: {{'Content-Type': 'application/json'}},
                    body: JSON.stringify({{
                        draft_id: draftId,
                        customer_id: customerId,
                        customer_name: customerName,
                        items: activeItems,
                        notes: document.getElementById('draftNotes').value
                    }})
                }});
                
                const data = await response.json();
                
                if (data.success) {{
                    alert('✅ Invoice ' + data.invoice_number + ' created! Total: R' + parseFloat(data.total).toFixed(2));
                    window.location.href = '/invoice/' + data.invoice_id;
                }} else {{
                    alert('❌ ' + (data.error || 'Failed to create invoice'));
                    btn.innerHTML = '✅ Proceed';
                    btn.disabled = false;
                }}
            }} catch (err) {{
                alert('Error: ' + err.message);
                btn.innerHTML = '✅ Proceed';
                btn.disabled = false;
            }}
        }}
        
        async function saveLater() {{
            try {{
                const response = await fetch('/api/orders/save-later', {{
                    method: 'POST',
                    headers: {{'Content-Type': 'application/json'}},
