    @app.route("/api/orders/approve", methods=["POST"])
    @login_required
    def api_order_approve():
        try:
            data = request.get_json()
            business = Auth.get_current_business()
            user = Auth.get_current_user()
            biz_id = business.get("id") if business else None
            if not biz_id:
                return jsonify({"success": False, "error": "No business"})
            draft_id = data.get("draft_id")
            customer_id = data.get("customer_id","")
            customer_name = data.get("customer_name","")
            items_data = data.get("items",[])
            notes = data.get("notes","")
            if not customer_id:
                return jsonify({"success": False, "error": "Select customer"})
            if not items_data:
                return jsonify({"success": False, "error": "No items"})

            invoice_items = []
            subtotal = Decimal("0")
            for item in items_data:
                if item.get("_removed"):
                    continue
                qty = Decimal(str(item.get("qty") or 1))
                price = Decimal(str(item.get("stock_price") or 0))
                lt = (qty * price).quantize(Decimal("0.01"))
                subtotal += lt
                invoice_items.append({"code": item.get("code",""), "description": item.get("stock_description") or item.get("description",""), "qty": float(qty), "price": float(price), "total": float(lt)})
            if subtotal <= 0:
                return jsonify({"success": False, "error": "Total must be > 0"})

            vat_amount = (subtotal * VAT_RATE).quantize(Decimal("0.01"))
            total = subtotal + vat_amount
            existing = db.get("invoices", {"business_id": biz_id}) or []
            inv_number = next_document_number("INV-", existing, "invoice_number")

            invoice = RecordFactory.invoice(business_id=biz_id, customer_id=customer_id, customer_name=customer_name, items=invoice_items, invoice_number=inv_number, date=today(), subtotal=float(subtotal), vat=float(vat_amount), total=float(total), status="outstanding", notes=notes, created_by=user.get("id","") if user else "")
            success, result = db.save("invoices", invoice)
            if not success:
                return jsonify({"success": False, "error": f"Save failed: {str(result)[:200]}"})
            invoice_id = invoice["id"]
            logger.info(f"[ORDER APPROVE] {inv_number}: R{float(total):.2f}")

            all_stock = db.get_all_stock(biz_id)
            sbc = {s.get("code","").upper(): s for s in all_stock if s.get("code")}
            for item in invoice_items:
                code = (item.get("code") or "").upper()
                if code and code in sbc:
                    si = sbc[code]
                    nq = float(si.get("qty") or 0) - float(item.get("qty") or 0)
                    db.update_stock(si["id"], {"qty": nq, "quantity": nq}, biz_id)

            try:
                cust = db.get_one("customers", customer_id)
                if cust:
                    db.update("customers", customer_id, {"balance": float(cust.get("balance",0)) + float(total)})
            except:
                pass

            try:
                create_journal_entry(biz_id, today(), f"Invoice {inv_number} - {customer_name}", inv_number, [
                    {"account_code": "1200", "debit": float(total), "credit": 0},
                    {"account_code": "4000", "debit": 0, "credit": float(subtotal)},
                    {"account_code": "2100", "debit": 0, "credit": float(vat_amount)}])
            except Exception as e:
                logger.error(f"[ORDER APPROVE] GL: {e}")

            try:
                db.save("order_drafts", {"id": draft_id, "status": "approved", "invoice_id": invoice_id, "invoice_number": inv_number, "reviewed_by": user.get("id","") if user else "", "reviewed_at": now()})
            except:
                pass

            return jsonify({"success": True, "invoice_id": invoice_id, "invoice_number": inv_number, "total": float(total)})
        except Exception as e:
            logger.error(f"[ORDER APPROVE] {e}", exc_info=True)
            return jsonify({"success": False, "error": str(e)})

