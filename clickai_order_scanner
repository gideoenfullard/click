    # ── ZANE SMART MATCH — Claude API does intelligent stock matching ──
    def zane_smart_match(ocr_items, all_stock, biz_id):
        if not ocr_items or not all_stock:
            return None

        stock_lines = []
        for s in all_stock[:2000]:
            code = s.get("code", "")
            desc = s.get("description", "")
            price = float(s.get("price") or s.get("selling_price") or 0)
            qty = float(s.get("qty") or s.get("quantity") or 0)
            sid = s.get("id", "")
            if code or desc:
                stock_lines.append(f"{code}|{desc}|R{price:.2f}|qty:{qty:.0f}|id:{sid}")

        stock_text = "\n".join(stock_lines)

        ocr_text = ""
        for i, item in enumerate(ocr_items):
            desc = item.get("description", "")
            qty = item.get("qty", 1)
            op = float(item.get("order_price") or item.get("price") or 0)
            ocr_text += f'{i+1}. "{desc}" — qty: {qty}, order price: R{op:.2f}\n'

        prompt = f"""You are Zane, stock matching expert for a South African steel/hardware supplier.
Match EACH customer order item to the BEST stock item from our database.

CUSTOMER ORDER ITEMS:
{ocr_text}

STOCK DATABASE (code|description|selling_price|qty_available|id):
{stock_text}

MATCHING RULES:
1. Match product type first (tube=tube, bolt=bolt, angle=angle, sheet=sheet, pipe=pipe)
2. Match dimensions: "25mm" matches "25", "M16x80" matches "M16X80"
3. Stock code abbreviations: TB=tube, BLT=bolt, NT=nut, WS=washer, AN=angle, PP=pipe, SH=sheet, PL=plate, FL=flange, EL=elbow
4. SS = stainless steel, could be "304" or "316"
5. Use OUR selling price, NOT the customer order price
6. line_total = qty x stock_price
7. confidence 0-100. If confidence < 60, set matched=false

Return ONLY valid JSON array:
[
  {{"order_index": 1, "order_description": "from order", "matched": true, "stock_id": "id", "stock_code": "CODE", "stock_description": "desc", "stock_price": 125.50, "qty": 10, "line_total": 1255.00, "confidence": 95, "flag_reason": ""}},
  {{"order_index": 2, "order_description": "unknown", "matched": false, "stock_id": "", "stock_code": "", "stock_description": "", "stock_price": 0, "qty": 5, "line_total": 0, "confidence": 0, "flag_reason": "Not found in stock"}}
]"""

        try:
            client = _anthropic_client
            message = client.messages.create(
                model="claude-sonnet-4-6", max_tokens=4000,
                messages=[{"role": "user", "content": prompt}]
            )
            raw = message.content[0].text.strip()
            matched = extract_json_from_text(raw)

            if matched and isinstance(matched, list):
                logger.info(f"[ZANE MATCH] {len(matched)} items, {sum(1 for m in matched if m.get('matched'))} matched")
                stock_by_id = {s.get("id", ""): s for s in all_stock}
                for item in matched:
                    sid = item.get("stock_id", "")
                    if sid and sid in stock_by_id:
                        item["stock_qty"] = float(stock_by_id[sid].get("qty") or stock_by_id[sid].get("quantity") or 0)
                    else:
                        item["stock_qty"] = 0
                    item["flagged"] = not item.get("matched", False)
                    if not item.get("flag_reason") and item["flagged"]:
                        item["flag_reason"] = "Not found in stock"
                    idx = item.get("order_index", 1) - 1
                    if 0 <= idx < len(ocr_items):
                        item["order_price"] = float(ocr_items[idx].get("order_price") or ocr_items[idx].get("price") or 0)
                    else:
                        item["order_price"] = 0
                    item["description"] = item.get("order_description", "")
                    item["code"] = item.get("stock_code", "")
                return matched
            else:
                logger.warning(f"[ZANE MATCH] Parse failed: {raw[:200]}")
                return None
        except Exception as e:
            logger.error(f"[ZANE MATCH] API failed: {e}")
            return None

    # ── FALLBACK basic matching if Zane API fails ──
    def fallback_match(ocr_items, all_stock):
        results = []
        for item in ocr_items:
            desc = (item.get("description") or "").strip()
            qty = float(item.get("qty") or 1)
            op = float(item.get("order_price") or item.get("price") or 0)
            if not desc:
                continue
            words = [w.lower() for w in desc.replace('-',' ').replace('/',' ').split() if len(w) > 1]
            best, best_score = None, 0
            for s in all_stock:
                combined = f"{(s.get('code') or '').lower()} {(s.get('description') or '').lower()}"
                matches = sum(1 for w in words if w in combined)
                pct = matches / len(words) if words else 0
                if matches > best_score and pct >= 0.5:
                    best_score = matches
                    best = s
            conf = round((best_score / len(words) * 100) if words else 0)
            if best and conf >= 50:
                sp = float(best.get("price") or best.get("selling_price") or 0)
                results.append({"description": desc, "stock_description": best.get("description",""), "code": best.get("code",""), "stock_id": best.get("id",""), "qty": qty, "stock_price": sp, "order_price": op, "line_total": round(qty*sp,2), "matched": True, "confidence": conf, "flagged": False, "flag_reason": "", "stock_qty": float(best.get("qty") or 0)})
            else:
                results.append({"description": desc, "stock_description": "", "code": "", "stock_id": "", "qty": qty, "stock_price": 0, "order_price": op, "line_total": 0, "matched": False, "confidence": conf, "flagged": True, "flag_reason": "Not found in stock", "stock_qty": 0})
        return results

    def match_customer(name_text, biz_id):
        if not name_text or not biz_id:
            return None
        customers = db.get("customers", {"business_id": biz_id}) or []
        nl = name_text.lower().strip()
        for c in customers:
            if nl == (c.get("name") or "").lower():
                return c
        for c in customers:
            cn = (c.get("name") or "").lower()
            if nl in cn or cn in nl:
                return c
        nw = set(nl.split())
        for c in customers:
            cw = set((c.get("name") or "").lower().split())
            if len(nw & cw) >= min(2, len(nw)):
                return c
        return None

    # ── CORE PIPELINE ──
    def run_order_pipeline(biz_id, user_id, ocr_data, source_type="scan",
                           source_sender="", source_subject="", source_filename="",
                           image_data="", customer_hint=""):
        ocr_items = ocr_data.get("items", [])
        if not ocr_items:
            return False, "No items found"

        all_stock = db.get_all_stock(biz_id)

        logger.info(f"[ORDER] Zane matching {len(ocr_items)} items vs {len(all_stock)} stock...")
        matched_items = zane_smart_match(ocr_items, all_stock, biz_id)
        if not matched_items:
            logger.warning("[ORDER] Zane failed, using fallback")
            matched_items = fallback_match(ocr_items, all_stock)
        if not matched_items:
            return False, "Could not match items"

        items_matched = sum(1 for i in matched_items if i.get("matched"))
        items_flagged = sum(1 for i in matched_items if i.get("flagged"))
        subtotal = Decimal("0")
        for item in matched_items:
            subtotal += Decimal(str(item.get("line_total", 0)))
        vat_amount = (subtotal * Decimal("0.15")).quantize(Decimal("0.01"))
        total = subtotal + vat_amount

        customer_name = customer_hint or ocr_data.get("customer_name", "")
        customer = match_customer(customer_name, biz_id) if customer_name else None
        if not customer and source_sender and "@" in source_sender:
            domain = source_sender.split("@")[-1].split(".")[0]
            if domain and len(domain) > 3:
                customer = match_customer(domain, biz_id)

        draft_id = generate_id()
        notes_parts = []
        if ocr_data.get("customer_ref"):
            notes_parts.append(f"PO/Ref: {ocr_data['customer_ref']}")
        if ocr_data.get("delivery_notes"):
            notes_parts.append(ocr_data["delivery_notes"])
        if source_sender:
            notes_parts.append(f"Email: {source_sender}")
        if source_subject:
            notes_parts.append(f"Subject: {source_subject}")

        draft = {
            "id": draft_id, "business_id": biz_id,
            "source_type": source_type, "source_sender": source_sender,
            "source_subject": source_subject, "source_filename": source_filename,
            "original_image": image_data[:500000] if image_data else "",
            "ocr_raw_text": json.dumps(ocr_data)[:5000],
            "customer_id": customer.get("id", "") if customer else "",
            "customer_name": customer.get("name", "") if customer else customer_name,
            "customer_matched": bool(customer),
            "items": json.dumps(matched_items),
            "subtotal": float(subtotal), "vat": float(vat_amount), "total": float(total),
            "status": "pending_review", "created_at": now(), "created_by": user_id,
            "notes": "\n".join(notes_parts)
        }

        success, result = db.save("order_drafts", draft)
        if success:
            logger.info(f"[ORDER] Draft {draft_id}: {len(matched_items)} items, {items_matched} matched, {items_flagged} flagged, R{float(total):.2f}")
            cust_display = customer.get("name") if customer else (customer_name or "Unknown")
            send_notification(biz_id,
                "New Order Ready",
                f"{cust_display} - {len(matched_items)} items, R{float(total):,.2f}" + (f" ({items_flagged} need attention)" if items_flagged else ""),
                link=f"/orders/review/{draft_id}")
            return True, {"id": draft_id, "customer_name": draft["customer_name"], "items_total": len(matched_items), "items_matched": items_matched, "items_flagged": items_flagged, "subtotal": float(subtotal), "vat": float(vat_amount), "total": float(total)}
        return False, f"Save failed: {str(result)[:200]}"

    # ── BACKGROUND EMAIL CHECKER ──
    class OrderEmailChecker:
        _running = False
        _interval = 300

        @classmethod
        def start(cls):
            if cls._running:
                return
            cls._running = True
            thread = threading.Thread(target=cls._run_loop, daemon=True)
            thread.start()
            logger.info(f"[ORDER EMAIL] Auto-checker started (every {cls._interval//60} min)")

        @classmethod
        def stop(cls):
            cls._running = False

        @classmethod
        def _run_loop(cls):
            time.sleep(60)
            while cls._running:
                try:
                    cls._check_all()
                except Exception as e:
                    logger.error(f"[ORDER EMAIL] Loop error: {e}")
                for _ in range(cls._interval // 10):
                    if not cls._running:
                        break
                    time.sleep(10)

        @classmethod
        def _check_all(cls):
            try:
                businesses = db.get("businesses", {}) or []
                for biz in businesses:
                    biz_id = biz.get("id")
                    imap_user = biz.get("imap_user")
                    imap_pass = biz.get("imap_pass")
                    imap_host = biz.get("imap_host", "imap.gmail.com")
                    if not imap_user or not imap_pass:
                        continue
                    try:
                        cls._check_one(biz_id, imap_host, imap_user, imap_pass)
                    except Exception as e:
                        logger.error(f"[ORDER EMAIL] {biz.get('name','')}: {e}")
                    time.sleep(2)
            except Exception as e:
                logger.error(f"[ORDER EMAIL] {e}")

        @classmethod
        def _check_one(cls, biz_id, imap_host, imap_user, imap_pass):
            emails = EmailScanner.fetch_new_emails(imap_host, imap_user, imap_pass)
            if not emails:
                return
            logger.info(f"[ORDER EMAIL] {len(emails)} emails for {biz_id}")
            order_kw = ["order", "bestelling", "po ", "purchase", "quote request", "kwotasie", "please supply", "lewer asb", "benodig", "need", "require", "rfq", "bestellys"]
            for email_data in emails:
                sender = email_data.get("sender", "")
                subject = email_data.get("subject", "")
                is_order = any(kw in subject.lower() for kw in order_kw)
                for att in email_data.get("attachments", []):
                    try:
                        processed = EmailScanner.process_attachment(att.get("data"), att.get("filename", "unknown"), att.get("content_type", "application/octet-stream"))
                        classification = processed.get("classification", "")
                        extracted = processed.get("extracted_data", {})
                        if (is_order or classification in ("customer_order", "purchase_order", "quote_request")) and extracted.get("items"):
                            img = base64.b64encode(att.get("data", b"")).decode("utf-8") if att.get("data") else ""
                            success, _ = run_order_pipeline(biz_id=biz_id, user_id="auto_email", ocr_data=extracted, source_type="email", source_sender=sender, source_subject=subject, source_filename=att.get("filename",""), image_data=img)
                            if success:
                                logger.info(f"[ORDER EMAIL] Auto-processed from {sender}")
                    except Exception as e:
                        logger.error(f"[ORDER EMAIL] Attachment error: {e}")

